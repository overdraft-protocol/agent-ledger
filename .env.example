# --- Server ---
HOST=127.0.0.1
PORT=3210
LOG_LEVEL=info
NODE_ENV=development

# --- Postgres ---
DATABASE_URL=postgres://agent_ledger:agent_ledger@127.0.0.1:5432/agent_ledger
PG_POOL_MAX=10

# --- OAuth (Ory Hydra) ---
OAUTH_ISSUER=http://127.0.0.1:4444
OAUTH_JWKS_URL=http://127.0.0.1:4444/.well-known/jwks.json
OAUTH_AUDIENCE=agent-ledger
OAUTH_REVOCATION_ENDPOINT=http://127.0.0.1:4445/oauth2/revoke
OAUTH_BLOCKLIST_POLL_MS=10000

# --- Security ---
# 32-byte hex; used to sign pagination cursors. Rotate via migration of cursor format.
CURSOR_HMAC_KEY=change-me-change-me-change-me-change-me-change-me-change-me-change

# --- Blob store ---
BLOB_DIR=./.blobs
BLOB_MAX_BYTES=4194304

# --- Limits ---
MAX_REQUEST_BYTES=2097152
RATE_LIMIT_WINDOW_SECONDS=1
RATE_LIMIT_DEFAULT_COST_PER_SECOND=200
